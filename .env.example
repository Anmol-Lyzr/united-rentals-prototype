# Banking Charge Dispute App - Environment Variables
# Copy this file to .env.local for local development

# ============================================
# OPTIONAL CONFIGURATION
# ============================================

# Call history persistence (optional). If set, call history is stored in MongoDB.
# If unset or MongoDB fails, the app falls back to localStorage.
# MONGODB_URI=mongodb://localhost:27017
# MONGODB_DB_NAME=ur_copilot
#
# If your password contains @, #, /, or other special characters, URL-encode them
# in MONGODB_URI (e.g. @ → %40, # → %23, / → %2F). Example: password "Anmol@2910"
# must appear as "Anmol%402910" in the URI.

# App URL (set automatically by Vercel, or override for custom domains)
# NEXT_PUBLIC_APP_URL=https://your-app.vercel.app

