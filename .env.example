# Banking Charge Dispute App - Environment Variables
# Copy this file to .env.local for local development

# ============================================
# OPTIONAL CONFIGURATION
# ============================================

# Call history persistence (optional). If set, call history is stored in MongoDB.
# If unset or MongoDB fails, the app falls back to localStorage.
# MONGODB_URI=mongodb://localhost:27017
# MONGODB_DB_NAME=ur_copilot
#
# If your password contains @, #, /, or other special characters, URL-encode them
# in MONGODB_URI (e.g. @ → %40, # → %23, / → %2F). Example: password "Anmol@2910"
# must appear as "Anmol%402910" in the URI.

# App URL (set automatically by Vercel, or override for custom domains)
# NEXT_PUBLIC_APP_URL=https://your-app.vercel.app

# ============================================
# API CONFIGURATION
# ============================================
# Lyzr Chat Assist (server-side proxy: POST /api/chat-assist)
#
# IMPORTANT:
# - Keep API keys server-side (do NOT prefix with NEXT_PUBLIC_)
# - Copy this file to .env.local and set values there for local dev
#
LYZR_API_BASE_URL=https://agent-prod.studio.lyzr.ai/v3/inference/chat/
LYZR_API_KEY=replace_me
LYZR_USER_ID=anmol@lyzr.ai
LYZR_CHAT_ASSIST_AGENT_ID=69b468c30bffa33a918d3bd2

# ============================================
# NOTES
# ============================================
# - No environment variables are required for basic deployment
# - API keys are embedded in the code for demo purposes
# - For production, consider moving sensitive values to env vars
